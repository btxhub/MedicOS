generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id         String           @id @default(cuid())
  name       String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  adjuntos   AdjuntoClinico[]
  evolutions Evolution[]
  hces       HCE[]
  patients   Patient[]
  users      User[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  doctorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

model Patient {
  id       String @id @default(cuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])
}

model HCE {
  id       String @id @default(cuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])
}

model Evolution {
  id       String @id @default(cuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])
}

model AdjuntoClinico {
  id       String @id @default(cuid())
  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [id])
}
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

