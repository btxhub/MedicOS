generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  idUser       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  emailUser    String   @unique
  passHashUser String
  activoUser   Boolean? @default(true)
  createdUser  DateTime? @default(now())
  updatedUser  DateTime? @default(now())
  refDocUser   String?  @db.Uuid
  refAsisUser  String?  @db.Uuid

  @@map("User")
}

model Doctor {
  idDoc      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  telDoc     String?
  waDoc      String?
  dirDoc     String?
  espDoc     String?
  licDoc     String?
  createdDoc DateTime? @default(now())
  updatedDoc DateTime? @default(now())

  pacientes  Paciente[]
  asistentes Asistente[]
  citas      Cita[]
  hces       HCE[]
  recetas    Receta[]

  @@map("Doctor")
}

model Paciente {
  idPac        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  refDocPac    String?  @db.Uuid
  telPac       String?
  waPac        String?
  emailPac     String?
  dirPac       String?
  grupoSangPac String?
  seguroPac    String?
  activoPac    Boolean? @default(true)
  createdPac   DateTime? @default(now())
  updatedPac   DateTime? @default(now())

  doctor       Doctor? @relation(fields: [refDocPac], references: [idDoc])
  citas        Cita[]
  hces         HCE[]
  recetas      Receta[]

  @@map("Paciente")
}

model Asistente {
  idAsis      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  refDocAsis  String?  @db.Uuid
  nomAsis     String
  apePatAsis  String
  apeMatAsis  String?
  docIdAsis   String?
  emailAsis   String?
  celAsis     String?
  telAsis     String?
  waAsis      String?
  activoAsis  Boolean? @default(true)
  createdAsis DateTime? @default(now())
  updatedAsis DateTime? @default(now())

  doctor      Doctor? @relation(fields: [refDocAsis], references: [idDoc])

  @@map("Asistente")
}

model Cita {
  idCita      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  refDocCita  String   @db.Uuid
  refPacCita  String   @db.Uuid
  fechaCita   DateTime
  horaCita    DateTime
  estadoCita  String?
  motivoCita  String?
  observCita  String?
  createdCita DateTime? @default(now())
  updatedCita DateTime? @default(now())

  doctor      Doctor   @relation(fields: [refDocCita], references: [idDoc])
  paciente    Paciente @relation(fields: [refPacCita], references: [idPac])

  @@map("Cita")
}

model HCE {
  idHce             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  refDocHce         String   @db.Uuid
  refPacHce         String   @db.Uuid
  motivoHce         String?
  enfActHce         String?
  antecedentesHce   String?
  alergiasHce       String?
  signosVitHce      String?
  exploracionHce    String?
  diagnosticoHce    String?
  tratamientoHce    String?
  planHce           String?
  consentimientoHce String?
  createdHce        DateTime? @default(now())
  updatedHce        DateTime? @default(now())

  doctor      Doctor   @relation(fields: [refDocHce], references: [idDoc])
  paciente    Paciente @relation(fields: [refPacHce], references: [idPac])
  recetas     Receta[]

  @@map("HCE")
}

model Receta {
  idReceta           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  refDocReceta       String   @db.Uuid
  refPacReceta       String   @db.Uuid
  refHceReceta       String?  @db.Uuid
  fechaReceta        DateTime?
  medicamentoReceta  String?
  dosisReceta        String?
  indicacionesReceta String?
  createdReceta      DateTime? @default(now())
  updatedReceta      DateTime? @default(now())

  doctor      Doctor   @relation(fields: [refDocReceta], references: [idDoc])
  paciente    Paciente @relation(fields: [refPacReceta], references: [idPac])
  hce         HCE?     @relation(fields: [refHceReceta], references: [idHce])

  @@map("Receta")
}
